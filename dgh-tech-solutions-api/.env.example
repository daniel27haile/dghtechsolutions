# Copy this file to .env and fill in your values.
# Never commit .env or .env.production to source control.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dghtechsolutionsDB?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
SERVER_URL=http://localhost:8000

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Dev:  https://dashboard.stripe.com/test/apikeys
# Prod: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_

# Dev:  stripe listen --forward-to localhost:8000/api/payments/webhook
# Prod: Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
